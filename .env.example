# Application
APP_NAME=gotaxi-backend
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
ALLOWED_HOSTS=["localhost","127.0.0.1"]
CORS_ORIGINS=["http://localhost:3000","https://app.gotaxi.bj"]

# Base de données
DATABASE_URL=postgresql+asyncpg://gotaxi:changeme@localhost:5432/gotaxi
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# OTP
OTP_EXPIRE_SECONDS=300
OTP_MAX_ATTEMPTS=5

# Mobile Money — MTN MoMo Collections
MTN_MOMO_API_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
MTN_MOMO_TARGET_ENV=sandbox
# MTN MoMo Disbursements (laisser vide = réutilise les credentials Collection)
MTN_MOMO_DISBURSE_SUB_KEY=
MTN_MOMO_DISBURSE_API_USER=
MTN_MOMO_DISBURSE_API_KEY=

MOOV_MONEY_API_URL=
MOOV_MONEY_MERCHANT_ID=
MOOV_MONEY_SECRET=

ORANGE_MONEY_API_URL=
ORANGE_MONEY_CLIENT_ID=
ORANGE_MONEY_CLIENT_SECRET=

# Celtis (Celtiis Bénin — BiBi Money)
CELTIS_API_URL=https://api-sandbox.celtiis.bj
CELTIS_CLIENT_ID=
CELTIS_CLIENT_SECRET=
CELTIS_MERCHANT_ID=

# FedaPay — agrégateur Mobile Money (MTN, Moov, Orange…)
# Clé sandbox : https://sandbox-dashboard.fedapay.com → API → Clés
# Clé production : https://app.fedapay.com → API → Clés
FEDAPAY_API_URL=https://sandbox-api.fedapay.com/v1
FEDAPAY_API_KEY=sk_sandbox_XXXXXXXXXXXXXXXXXXXXXXXX

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+229xxx

# Firebase (Push)
FIREBASE_CREDENTIALS_PATH=./keys/firebase.json

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
AWS_S3_BUCKET=gotaxi-uploads